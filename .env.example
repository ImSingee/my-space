# ── Platform control-plane database ──────────────────────────────
# Drizzle schema + Better Auth tables live here.
DATABASE_URL=postgres://postgres@localhost:5432/byod_platform

# Admin connection used to create/drop a database per app. Each app's
# DATABASE_URL (host, port, credentials) is inferred from this URL.
APP_DATABASE_URL=postgres://postgres@localhost:5432/postgres

# ── Platform secret ───────────────────────────────────────────────────────
# Required root secret used to derive every app database password.
# Use a long random string (e.g. `openssl rand -hex 32`).
SECRET=change-me-to-a-long-random-string

# ── Application URL ──────────────────────────────────────────────
# Public origin of the app (scheme, host, and optional port only).
APP_URL=http://localhost:3700

# ── Better Auth ──────────────────────────────────────────────────
# Optional auth-session signing secret. Defaults to SECRET when unset.
# BETTER_AUTH_SECRET=use-a-different-long-random-string
# Self-service sign-up is a runtime platform setting (Settings → Users), not
# an env var. Fresh installs start with sign-up open so the owner account can
# be created; sign-in always works regardless.

# ── Runtime data directory ───────────────────────────────────────
# Where the platform stores agent-authored app/workflow sources, Git repos,
# build artifacts, per-app storage and agent worktrees. Defaults to
# `<repo>/workspace`. A relative value resolves against the server's working
# directory; an absolute path is used as-is. `pnpm dev`/`pnpm preview` set this
# to `../my-space-data` so local runtime data stays outside the repo checkout.
# HATCH_DATA_DIR=../my-space-data
