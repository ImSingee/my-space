# ── Platform control-plane database ──────────────────────────────
# Drizzle schema + Better Auth tables live here.
DATABASE_URL=postgres://postgres@localhost:5432/byod_platform

# Admin connection used to create/drop a database per app. Each app's
# DATABASE_URL (host, port, credentials) is inferred from this URL.
APP_DATABASE_URL=postgres://postgres@localhost:5432/postgres

# ── Better Auth ──────────────────────────────────────────────────
# Signs auth sessions — use a long random string (e.g. `openssl rand -hex 32`).
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# Base URL of the app (dev server runs on port 3700).
BETTER_AUTH_URL=http://localhost:3700
