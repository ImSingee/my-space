{
  "name": "my-space",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.12.2",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "node .output/server/index.mjs",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "lint": "oxlint .",
    "format": "oxfmt --write . && oxlint . --fix && oxfmt --write . && oxlint .",
    "check:types": "tsc --noEmit",
    "migrations:generate": "drizzle-kit generate",
    "migrations:apply": "drizzle-kit migrate",
    "migrations:push": "drizzle-kit push",
    "auth:generate": "pnpx auth@latest generate --config ./src/auth/server.ts --output ./src/db/auth-schema.ts -y && pnpm format",
    "db:seed": "tsx scripts/seed-db.ts",
    "drizzle:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@mantine/carousel": "^9.3.1",
    "@mantine/charts": "^9.3.1",
    "@mantine/code-highlight": "^9.3.1",
    "@mantine/core": "^9.3.1",
    "@mantine/dates": "^9.3.1",
    "@mantine/dropzone": "^9.3.1",
    "@mantine/form": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@mantine/modals": "^9.3.1",
    "@mantine/nprogress": "^9.3.1",
    "@mantine/spotlight": "^9.3.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.168.18",
    "better-auth": "^1.6.15",
    "copy-to-clipboard": "^4.0.2",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.9",
    "nitro": "3.0.260603-beta",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.2.0",
    "web-vitals": "^5.3.0"
  }
}
